  "private": true,
  "type": "module",
  "description": "Interactive 3D cargo transportation calculator with pallet configurator",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "build:protected": "tsc && vite build",
